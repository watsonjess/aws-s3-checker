{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3SecurityChecker",
            "Effect": "Allow",
            "Action": [
                "s3:ListAllMyBuckets",
                "s3:GetBucketPublicAccessBlock",
                "s3:GetBucketPolicyStatus"
            ],
            "Resource": "*"
        }
    ]
}